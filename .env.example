# ─────────────────────────────────────────────────────────────
# Cairn — Variables d'environnement
# Copiez ce fichier : cp .env.example .env.local
# Ne commitez jamais .env.local (il est dans .gitignore)
# ─────────────────────────────────────────────────────────────

# ── Base de données ───────────────────────────────────────────
# PostgreSQL hébergé sur Neon (neon.tech — plan gratuit suffisant)
# Console Neon → votre projet → "Connection string" (mode "pooled")
DATABASE_URL=

# ── Auth.js v5 ────────────────────────────────────────────────
# Secret de session — générer avec : npx auth secret
# En production : chaîne aléatoire longue (32+ chars)
AUTH_SECRET=

# URL de base de l'application
# En local : http://localhost:3000
# En production : https://cairn.lat (ou votre domaine)
AUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# 1. Créer un projet (ou utiliser un existant)
# 2. Activer "Identity Toolkit API" dans la bibliothèque d'APIs
# 3. Créer des identifiants OAuth 2.0 (type : Application Web)
# 4. Dans "URI de redirection autorisées", ajouter :
#    http://localhost:3000/api/auth/callback/google  (dev)
#    https://cairn.lat/api/auth/callback/google      (prod)
# Note : mettre les URLs dans "URI de redirection", PAS dans "Origines autorisées"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend — emails d'invitation ─────────────────────────────
# Créer un compte sur resend.com
# API Keys → Create API key
RESEND_API_KEY=

# Adresse expéditeur (optionnel)
# · Laisser vide en local → emails envoyés depuis onboarding@resend.dev
#   (fonctionne sans aucune configuration DNS)
# · En production avec domaine vérifié dans Resend :
#   RESEND_FROM_EMAIL="Cairn <noreply@cairn.lat>"
# Pour vérifier cairn.lat dans Resend : Resend → Domains → Add domain
# → ajouter les enregistrements DNS SPF/DKIM fournis par Resend
RESEND_FROM_EMAIL=

# ── MailerLite — newsletter landing page ─────────────────────
# Optionnel — utilisé uniquement pour le formulaire de pré-inscription
# sur la page d'accueil (cairn.lat)
# MailerLite → Integrations → Developer API
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
